{
  "type": "module",
  "name": "service-budget-server",
  "packageManager": "yarn@4.11.0",
  "scripts": {
    "build": "tsup src/server.ts --format esm --out-dir dist",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/jwt": "^10.0.0",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.20.0",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
